# Port to run/expose the MCP server or other configuration (if applicable)
# MCP_K8S_LOG_LEVEL: Logging level (DEBUG, INFO, WARNING, ERROR)
MCP_K8S_LOG_LEVEL=INFO

# Default NFS-backed StorageClass name for matching in choose_storage_option
MCP_K8S_DEFAULT_NFS_STORAGE_CLASS=nfs

# Path to the kubeconfig file (defaults to ~/.kube/config if not set)
# KUBECONFIG=~/.kube/config

# Optional list of allowed namespaces for deployment (comma separated).
# If empty, all namespaces are allowed.
MCP_K8S_ALLOWED_NAMESPACES=
