# Configuration file for MCP Kubernetes App Deployment Orchestration Server

# Logging configuration
logging:
  level: "INFO"

# Kubernetes settings
kubernetes:
  # Path to kubeconfig. If not specified, the server loads default system config.
  kubeconfig_path: ""
  
  # Default NFS StorageClass used to check dynamic PVC capabilities
  default_nfs_storage_class: "nfs"
  
  # Namespaces allowed for deployment (if empty, allows all namespaces)
  allowed_namespaces: []

# Default deployment values
defaults:
  replicas: 1
  container_port: 80
  storage_size: "10Gi"
